OL,0,        ECIMSBWebfax 1   F403A1781387266
OL,3,CGrenfell remembered on final
OL,4,Canniversary before tower's complete
OL,5,Ctake down
OL,7,FPotential offences under consideration
OL,8,Finclude corporate gross negligence
OL,9,Fmanslaughter, fraud, health and safety
OL,10,Fbreaches, and misconduct in public
OL,11,Foffice.
OL,13,FGrenfell survivor Edward Daffarn said,
OL,14,Fwhile the update was "encouraging",
OL,15,Fthe continued "wait for justice is
OL,16,Ftortuous, and it's an old expression,
OL,17,Fbut justice delayed is justice denied".
OL,26,@vD@VOUvD@bO]wD@OOUyD@fO]
OL,1,W h7}h7}j7}h7}h7}                 G2/11
