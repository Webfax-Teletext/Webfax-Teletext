FL,426,420,120,260,000,100
PN,42503
SC,0003
CT,2,C
PS,c008
OL,0,        ECIMSBWebfax 1   F425A1777551071
OL,3,CMan who killed father-of-two in
OL,4,CAustralia found mentally unfit for
OL,5,Ctrial
OL,7,FShe ordered Summers-Smith to be held
OL,8,Findefinitely in a mental health
OL,9,Ffacility.
OL,1,W~k4~s hw1~k4~c1 hw}h7}j7}        G3/7
OL,2,W/*%+, "-$/*%+.!+,*%/*%/*-'T(,,,,,,,,,,,
