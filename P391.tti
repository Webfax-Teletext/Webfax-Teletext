FL,392,390,120,260,000,100
PN,39109
SC,0009
CT,2,C
PS,c008
OL,0,        ECIMSBWebfax 1   F391A1775758264
OL,3,C'Calculating' child abuser used Roblox
OL,4,Cto find schoolgirl victim 220 miles
OL,5,Caway
OL,7,F"She was in this controlling
OL,8,Frelationship, you could say, with
OL,9,Fsomeone who's a lot older. She had no
OL,10,Fway of getting out of it.
OL,12,F"She was probably too ashamed to say
OL,13,Fanything to me because of what was on
OL,14,Fher phone."
OL,1,W~k4j5 hw1~k4~c1 hw}h7}j7}      G9/17
OL,2,W/*%+.-' "-$/*%+.!+,*%/*%/*-'T(,,,,,,,,,
