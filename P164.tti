OL,0,        ECIMSBWebfax 1   F164A1778306711
OL,1,Wj5hw1~{4k7juhw1{$             G2/2
OL,2,W+.-'"-$/*%*%*%/"-$/*%Q,,,,,,,,,,,,,,,,,
OL,3,GNorth East
OL,4,
OL,5,CSunday:FCold start Sunday, perhaps
OL,6,Ffrosty, then dry with sunny spells
OL,7,Fduring the morning before turning
OL,8,Fincreasingly cloudy by the afternoon.
OL,9,FWinds breezy and blustery along the
OL,10,Fcoast.
OL,11,
OL,12,COutlook for Monday to Wednesday:FBand
OL,13,Fof rain clears south early Monday,
OL,14,Ffollowed by brighter spells. Further
OL,15,Frain overnight and Tuesday morning,
OL,16,Fwith showers following. Wednesday
OL,17,Fbreezy with widespread heavy showers,
OL,18,Fpossibly thundery.
OL,23,QppppppppppppppppppppGSource: Met Office
