FL,440,430,120,260,000,100
PN,43903
SC,0003
CT,2,C
PS,c008
OL,0,        ECIMSBWebfax 1   F439A1776355854
OL,3,CMan found stabbed to death in garden
OL,4,Cnamed as housemate charged with his
OL,5,Cmurder
OL,7,F"The formal identification process has
OL,8,Fnot yet been completed but we are
OL,9,Freleasing Jamie's name at this point,
OL,10,Fwith his family's knowledge, because
OL,11,Fit will form part of the court
OL,12,Fproceedings and be a matter of public
OL,13,Frecord.
OL,1,W~s1j5 hw1~k4~c1 hw}h7}j7}      G3/6
OL,2,W,.!+.-' "-$/*%+.!+,*%/*%/*-'T(,,,,,,,,,
