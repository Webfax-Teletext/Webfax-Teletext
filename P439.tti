PN,43911
SC,0011
CT,2,C
PS,c008
OL,0,        ECIMSBWebfax 1   F439A1782308901
OL,3,C'Health board failed our pregnant
OL,4,Cdaughter' says family after epilepsy
OL,5,Cdeath
OL,7,F"We would like to reiterate our
OL,8,Fsincere condolences to Megan
OL,9,FGardiner's family following their
OL,10,Ftragic loss."
OL,12,F"Cardiff and Vale University Health
OL,13,FBoard fully participated in the
OL,14,Finquest process", and "provided the
OL,15,Fadditional information requested by
OL,16,Fthe Coroner".
OL,26,@oD@AOUrD@MO]tD@AOUvD@PO]vD@WOUxD@LO]
OL,1,Wj5hw}j5 ~shws                  G11/12
