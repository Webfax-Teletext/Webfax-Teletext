OL,0,        ECIMSBWebfax 1   F174A1780027431
OL,1,Wj5hw1~{4k7juhw1{$             G2/2
OL,2,W+.-'"-$/*%*%*%/"-$/*%Q,,,,,,,,,,,,,,,,,
OL,3,GOrkney & Shetland
OL,4,
OL,5,CSaturday:FEarly cloud and rain across
OL,6,FShetland soon clears, then a bright
OL,7,Fmorning with some sunny spells.
OL,8,FHowever the afternoon looks cloudier
OL,9,Fwith rain, most persistent and
OL,10,Foccasionally heavy across Orkney.
OL,11,
OL,12,COutlook for Sunday to Tuesday:
OL,13,FOccasionally heavy, perhaps thundery,
OL,14,Frain early Sunday but becoming drier
OL,15,Fand brighter. Rather cloudy Monday
OL,16,Fwith patchy rain or showers then
OL,17,Fcloudy on Tuesday with occasional
OL,18,Frain. Mainly light winds.
OL,23,QppppppppppppppppppppGSource: Met Office
