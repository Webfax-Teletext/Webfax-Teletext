OL,0,        ECIMSBWebfax 1   F175A1778746039
OL,1,Wj5hw1~{4k7juhw1{$             G2/2
OL,2,W+.-'"-$/*%*%*%/"-$/*%Q,,,,,,,,,,,,,,,,,
OL,3,GHighlands & Eilean Siar
OL,4,
OL,5,CFriday:FA few showers, mainly around
OL,6,Fcoastal areas, and sunny spells, the
OL,7,Fbest of these towards the Great Glen
OL,8,Fand the south. Occasionally fresh
OL,9,Fnorthwesterly winds easing.
OL,10,
OL,11,COutlook for Saturday to Monday:FDry,
OL,12,Fbright morning Saturday but cloud
OL,13,Fincreasing with rain in west later.
OL,14,FRain spreading east overnight,
OL,15,Fclearing Sunday morning with showers
OL,16,Ffollowing. Rather cloudy Monday with
OL,17,Foccasional rain. Becoming milder.
OL,23,QppppppppppppppppppppGSource: Met Office
