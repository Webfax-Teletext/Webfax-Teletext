OL,0,        ECIMSBWebfax 1   F175A1780027431
OL,1,Wj5hw1~{4k7juhw1{$             G2/2
OL,2,W+.-'"-$/*%*%*%/"-$/*%Q,,,,,,,,,,,,,,,,,
OL,3,GHighlands & Eilean Siar
OL,4,
OL,5,CSaturday:FMostly cloudy with outbreaks
OL,6,Fof rain, heaviest and most persistent
OL,7,Facross western parts, the rain turning
OL,8,Fmore showery in the afternoon, with a
OL,9,Frisk of thunder. Occasionally fresh
OL,10,Fsoutherly winds.
OL,11,
OL,12,COutlook for Sunday to Tuesday:FHeavy,
OL,13,Fshowery overnight rain soon clearing
OL,14,Fthen sunny spells and showers Sunday.
OL,15,FMainly dry and bright Monday by cloud
OL,16,Fincreasing with evening rain, with
OL,17,Fsunny spells and showers Tuesday.
OL,23,QppppppppppppppppppppGSource: Met Office
