OL,0,        ECIMSBWebfax 1   F175A1778641445
OL,1,Wj5hw1~{4k7juhw1{$             G2/2
OL,2,W+.-'"-$/*%*%*%/"-$/*%Q,,,,,,,,,,,,,,,,,
OL,3,GHighlands & Eilean Siar
OL,4,
OL,5,CThursday:FAnother rather cold day with
OL,6,Fa mix of sunny spells and showers, the
OL,7,Fshowers tending to become less heavy
OL,8,Fthrough the afternoon and evening.
OL,9,FFresh to strong northerly winds.
OL,10,
OL,11,COutlook for Friday to Sunday:FShowers
OL,12,Fand northerly winds ease from west
OL,13,Fthrough Friday. Bright start Saturday
OL,14,Fcloud and rain edging east in
OL,15,Fafternoon. Morning rain Sunday then
OL,16,Fsunny spells and showers in afternoon.
OL,23,QppppppppppppppppppppGSource: Met Office
