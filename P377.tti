CT,2,C
PS,c008
OL,0,        ECIMSBWebfax 1   F377A1783689573
OL,3,CThousands take part in Pride in London
OL,4,Cparade
OL,6,FLondon-based football teams including
OL,7,FArsenal, West Ham and Crystal Palace
OL,8,Falso had floats in the parade.
OL,10,FActivist Peter Tatchell said Fifa was
OL,11,F"doing nothing" about 11 countries
OL,12,Fbanning gay footballers at the World
OL,13,FCup.
OL,26,@sD@AOUsD@OO]
OL,1,W h7}h7}j7}h7}h7}                 G6/15
OL,2,W+,"-'*%/*-'"-'*%/T(,,,,,,,,,,,,,,,,,,,,
