OL,0,        ECIMSBWebfax 1   F313A1779811864
OL,3,CMore temperature records could tumble
OL,4,Cafter scorching bank holiday
OL,6,FThe May high record was surpassed in:
OL,7,FHeathrow, Greater London (34.4C);
OL,8,FNortholt, Greater London (34.2C);
OL,9,FTeddington Bushy Park, Middlesex
OL,10,F(34C); Benson, Oxfordshire (33.6C);
OL,11,FWisley, Surrey (33.3C); Reading
OL,12,FUniversity, Berkshire (33.2C);
OL,13,FWellesbourne, Warwickshire (33.2C);
OL,14,FCippenham, Berkshire (33.0C); Brize
OL,15,FNorton, Oxfordshire (32.9C);
OL,16,FCharlwood, Surrey (32.9C); Houghton
OL,17,FHall, Norfolk (32.9C) and Santon
OL,18,FDownham, Suffolk (32.9C).
OL,20,FIt was matched at Marham, Norfolk and
OL,21,FWoburn, Bedfordshire.
OL,1,W~k4~sj5j5~s1G                   G11/13
OL,2,W/*%+,"-/.!,.!T,,,,,,,,,,,,,,,,,,,,,,,,,
