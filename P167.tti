OL,0,        ECIMSBWebfax 1   F167A1778904284
OL,1,Wj5hw1~{4k7juhw1{$             G2/2
OL,2,W+.-'"-$/*%*%*%/"-$/*%Q,,,,,,,,,,,,,,,,,
OL,3,GEast Midlands
OL,4,
OL,5,CSunday:FSunny spells and isolated
OL,6,Fshowers, these most likely across
OL,7,Fwestern areas, until late afternoon.
OL,8,FThen frequent showers will spread
OL,9,Feast, locally heavy with a small
OL,10,Fchance of hail and thunder.
OL,11,
OL,12,COutlook for Monday to Wednesday:FMonday
OL,13,Fsunshine and scattered sometimes heavy
OL,14,Fshowers. Rain and strong winds arrive
OL,15,Fovernight. Tuesday breezy with
OL,16,Ffrequent heavy showers. Wednesday
OL,17,Fbreezy still, bright spells and
OL,18,Fisolated showers, feeling slightly
OL,19,Fwarmer.
OL,23,QppppppppppppppppppppGSource: Met Office
