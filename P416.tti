PN,41608
SC,0008
CT,2,C
PS,c008
OL,0,        ECIMSBWebfax 1   F416A1778937070
OL,3,CStudent dies and two others being
OL,4,Ctreated after meningitis outbreak in
OL,5,CReading
OL,7,F"Please be alert to the signs and
OL,8,Fsymptoms of meningococcal meningitis
OL,9,Fand septicaemia."
OL,1,W~s1x0~s1~s hw1~k4~c1 hw}h7}j7}   G8/8
