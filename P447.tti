OL,0,        ECIMSBWebfax 1   F447A1779970272
OL,3,C'E-pharmacy' among Stormont projects
OL,4,Cto benefit from #100m fund
OL,6,FAn "e-Pharmacy" initiative is set to
OL,7,Freceive the largest portion (#42
OL,8,Fmillion) to deliver electronic
OL,9,Fprescription transfer and a new
OL,10,Fdigital platform for community
OL,11,Fpharmacy clinical services.
OL,26,@nD@DOUnD@OO]
OL,1,W~k4 jw=hw1 hw}h7}j7}            G2/9
OL,2,W/*% /*%/"-$+,*%/*%/*-'T(,,,,,,,,,,,,,,,
