PN,38209
SC,0009
CT,2,C
PS,c008
OL,0,        ECIMSBWebfax 1   F382A1782461893
OL,3,CTikTok influencer charged with
OL,4,Cboyfriend's murder in Dubai 'faces
OL,5,Cfiring squad'
OL,7,F"We are calling for Brooke to be
OL,8,Freleased on bail pending the outcome
OL,9,Fof the investigation.
OL,11,F"She should be afforded protection,
OL,12,Fappropriate medical care, legal
OL,13,Frepresentation and immediate British
OL,14,Fconsular assistance while the
OL,15,Finvestigation proceeds."
OL,26,@oD@AOUsD@AOUwD@XO]
OL,1,W~s1x0~s1~s hw1~k4~c1 hw}h7}j7}   G9/10
OL,2,W,.!" ,.!+, "-$/*%+.!+,*%/*%/*-'T(,,,,,,
