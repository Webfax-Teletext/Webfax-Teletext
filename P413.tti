FL,414,410,140,120,000,100
PN,41303
SC,0003
CT,2,C
PS,c008
OL,0,        ECIMSBWebfax 1   F413A1782850701
OL,3,CKincora sex abuse victim receives
OL,4,C#100k as authorities express 'deep
OL,5,Cregret'
OL,7,FAt the High Court on Tuesday, counsel
OL,8,Ffor Mr Kerr, Monye Anyadike-Danes KC,
OL,9,Fconfirmed that action has been
OL,10,Fresolved.
OL,12,FThe defendants, who deny liability,
OL,13,Fare to pay him #100,000 plus costs in
OL,14,Fa final settlement of all claims
OL,15,Fagainst them.
OL,1,W~k4 jw=hw1 hw}h7}j7}            G3/10
OL,2,W/*% /*%/"-$+,*%/*%/*-'T(,,,,,,,,,,,,,,,
