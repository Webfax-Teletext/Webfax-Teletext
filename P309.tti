FL,310,300,200,140,000,100
PN,30905
SC,0005
CT,2,C
PS,c008
OL,0,        ECIMSBWebfax 1   F309A1775149553
OL,3,CGovernment withdraws extra training
OL,4,Cplaces after doctors fail to call off
OL,5,Cstrike
OL,7,F"Because the BMA resident doctor
OL,8,Fcommittee has not agreed to call off
OL,9,Fthese strikes and put an offer to
OL,10,Fmembers, we will now not be able to
OL,11,Fdeliver the 1,000 extra training
OL,12,Fplaces which the BMA asked for," the
OL,13,Fdepartment said.
OL,26,@oD@AOUtD@`O]
OL,1,W~k4~sj5j5~s1G                    G5/10
OL,2,W/*%+,"-/.!,.!T,,,,,,,,,,,,,,,,,,,,,,,,,
