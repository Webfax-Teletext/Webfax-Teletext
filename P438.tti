OL,13,FEngland, #189.71, #250.96
OL,15,FScotland, #179.95, #239.56
OL,17,FWales, #223.59, #262.48
OL,19,FEast Midlands, #188.18, #219.30
OL,21,FEast of England, #190.66, #271.88
